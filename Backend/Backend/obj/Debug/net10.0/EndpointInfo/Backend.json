{
  "openapi": "3.1.1",
  "info": {
    "title": "Backend | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7086"
    },
    {
      "url": "http://localhost:5082"
    }
  ],
  "paths": {
